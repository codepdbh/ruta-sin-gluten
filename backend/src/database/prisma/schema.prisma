generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum BusinessType {
  TIENDA
  EMPRENDIMIENTO
  PANADERIA
  CAFETERIA
  RESTAURANTE
  OTRO
}

enum SellerProfileStatus {
  DRAFT
  SUBMITTED
  PENDING_VERIFICATION
  OBSERVED
  APPROVED
  REJECTED
  SUSPENDED
}

enum GlutenType {
  LIBRE_GLUTEN
  OPCION_LIBRE_GLUTEN
  CONSULTAR
}

enum FoodSafetyModality {
  CIEN_PORCIENTO_LIBRE_GLUTEN
  CON_OPCIONES
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
  NO_INFORMADO
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  OBSERVED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

model User {
  id                              String                   @id @default(uuid())
  name                            String
  email                           String                   @unique
  passwordHash                    String                   @map("password_hash")
  role                            Role                     @default(USER)
  phone                           String?
  avatarUrl                       String?                  @map("avatar_url")
  emailVerifiedAt                 DateTime?                @map("email_verified_at")
  emailVerificationTokenHash      String?                  @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime?                @map("email_verification_token_expires_at")
  passwordResetTokenHash          String?                  @map("password_reset_token_hash")
  passwordResetTokenExpiresAt     DateTime?                @map("password_reset_token_expires_at")
  createdAt                       DateTime                 @default(now()) @map("created_at")
  sellerProfile                   SellerProfile?
  suggestions                     PlaceSuggestion[]
  placeRatings                    PlaceRating[]
  reviewedVerifications           VerificationSubmission[] @relation("VerificationReviewer")

  @@index([emailVerificationTokenHash])
  @@index([passwordResetTokenHash])
  @@map("users")
}

model SellerProfile {
  id                      String                   @id @default(uuid())
  userId                  String                   @unique @map("user_id")
  businessName            String                   @map("business_name")
  ownerName               String                   @map("owner_name")
  logoUrl                 String?                  @map("logo_url")
  businessType            BusinessType             @map("business_type")
  description             String?
  country                 String                   @default("Bolivia")
  department              String
  city                    String
  whatsapp                String
  hasPhysicalStore        Boolean                  @default(false) @map("has_physical_store")
  hasShipping             Boolean                  @default(false) @map("has_shipping")
  status                  SellerProfileStatus      @default(DRAFT)
  isPublic                Boolean                  @default(false) @map("is_public")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainLocation            SellerMainLocation?
  deliveryPoints          SellerDeliveryPoint[]
  shippingAreas           SellerShippingArea[]
  products                Product[]
  foodSafetyInfo          FoodSafetyInfo?
  verificationSubmissions VerificationSubmission[]
  ratings                 PlaceRating[]

  @@index([status, isPublic])
  @@map("seller_profiles")
}

model PlaceRating {
  id              String        @id @default(uuid())
  sellerProfileId String        @map("seller_profile_id")
  userId          String        @map("user_id")
  score           Int
  comment         String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sellerProfileId, userId])
  @@index([sellerProfileId, score])
  @@index([userId])
  @@map("place_ratings")
}

model SellerMainLocation {
  id              String                                @id @default(uuid())
  sellerProfileId String                                @unique @map("seller_profile_id")
  addressText     String                                @map("address_text")
  reference       String?
  lat             Float?
  lng             Float?
  geom            Unsupported("geometry(Point, 4326)")?
  createdAt       DateTime                              @default(now()) @map("created_at")
  sellerProfile   SellerProfile                         @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@map("seller_main_location")
}

model SellerDeliveryPoint {
  id              String                                @id @default(uuid())
  sellerProfileId String                                @map("seller_profile_id")
  name            String
  addressText     String                                @map("address_text")
  reference       String?
  schedule        String?
  lat             Float?
  lng             Float?
  geom            Unsupported("geometry(Point, 4326)")?
  isActive        Boolean                               @default(true) @map("is_active")
  createdAt       DateTime                              @default(now()) @map("created_at")
  sellerProfile   SellerProfile                         @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId, isActive])
  @@map("seller_delivery_points")
}

model SellerShippingArea {
  id              String        @id @default(uuid())
  sellerProfileId String        @map("seller_profile_id")
  department      String
  city            String?
  deliveryType    String        @map("delivery_type")
  cost            Float?
  etaText         String?       @map("eta_text")
  createdAt       DateTime      @default(now()) @map("created_at")
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@map("seller_shipping_areas")
}

model Product {
  id              String         @id @default(uuid())
  sellerProfileId String         @map("seller_profile_id")
  name            String
  category        String
  description     String?
  price           Float
  stockQty        Float          @map("stock_qty")
  stockUnit       String         @map("stock_unit")
  glutenType      GlutenType     @map("gluten_type")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  sellerProfile   SellerProfile  @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  photos          ProductPhoto[]

  @@index([sellerProfileId, isActive])
  @@map("products")
}

model ProductPhoto {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  fileUrl   String  @map("file_url")
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_photos")
}

model FoodSafetyInfo {
  id                     String             @id @default(uuid())
  sellerProfileId        String             @unique @map("seller_profile_id")
  modality               FoodSafetyModality
  crossContaminationRisk RiskLevel          @default(NO_INFORMADO) @map("cross_contamination_risk")
  separateUtensils       Boolean            @default(false) @map("separate_utensils")
  separateArea           Boolean            @default(false) @map("separate_area")
  trainedStaff           Boolean            @default(false) @map("trained_staff")
  notes                  String?
  sellerProfile          SellerProfile      @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@map("food_safety_info")
}

model VerificationSubmission {
  id              String             @id @default(uuid())
  sellerProfileId String             @map("seller_profile_id")
  videoUrl        String             @map("video_url")
  status          VerificationStatus @default(PENDING)
  adminNotes      String?            @map("admin_notes")
  reviewedBy      String?            @map("reviewed_by")
  reviewedAt      DateTime?          @map("reviewed_at")
  submittedAt     DateTime           @default(now()) @map("submitted_at")
  sellerProfile   SellerProfile      @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  reviewer        User?              @relation("VerificationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status, submittedAt])
  @@map("verification_submissions")
}

model PlaceSuggestion {
  id          String           @id @default(uuid())
  userId      String?          @map("user_id")
  placeName   String           @map("place_name")
  typeGuess   String           @map("type_guess")
  addressText String           @map("address_text")
  reference   String?
  lat         Float?
  lng         Float?
  comment     String?
  status      SuggestionStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("place_suggestions")
}
